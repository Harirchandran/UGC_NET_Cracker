{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "netcracker-question-schema-1.0",
  "title": "NETCracker reviewed UGC-NET question",
  "type": "object",
  "required": ["id","year","examCycle","paper","questionNumber","question","options","source","sourceUrl","transcriptionStatus","contentVerification"],
  "properties": {
    "id": {"type":"string","minLength":1},
    "year": {"type":"integer","minimum":2000},
    "examCycle": {"type":"string","minLength":1},
    "paper": {"enum":[1,2]},
    "legacyPaper": {"enum":[1,2,3]},
    "questionNumber": {"type":"integer","minimum":1},
    "question": {"type":"string","minLength":1},
    "passage": {"type":"string"},
    "options": {"type":"array","minItems":4,"maxItems":4,"items":{"type":"string"}},
    "optionAlt": {"type":"array","minItems":4,"maxItems":4,"items":{"type":"string","minLength":1}},
    "answer": {"type":"integer","minimum":0,"maximum":3},
    "answers": {"type":"array","minItems":1,"uniqueItems":true,"items":{"type":"integer","minimum":0,"maximum":3}},
    "dropped": {"type":"boolean"},
    "scored": {"type":"boolean"},
    "sourcePage": {"type":"integer","minimum":1},
    "questionId": {"type":"string"},
    "source": {"type":"string","minLength":1},
    "sourceUrl": {"type":"string"},
    "answerVerification": {"type":"string"},
    "transcriptionStatus": {"type":"string","minLength":1},
    "transcriptionConfidence": {"type":"number","minimum":0,"maximum":1},
    "contentVerification": {"type":"string","minLength":1},
    "stemVectorSvg": {"type":"string"},
    "optionVectorSvgs": {"type":"array","minItems":4,"maxItems":4,"items":{"type":"string"},"description":"Four safe inline SVGs; raster images and scripts are forbidden."},
    "sourceVectorSvgs": {"type":"array","items":{"type":"string"}},
    "visualType": {"type":"string"},
    "reviewNotes": {"type":"string"}
  }
}
